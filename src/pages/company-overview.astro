---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/url';
---

<Layout title="대표 인사말" description="하온 노동법률사무소 대표 노무사 인사말 및 사무소 소개">

  <!-- Page header -->
  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-sm text-gold-400 mb-2">
        <a href={url("/")} class="hover:underline">홈</a>
        <span class="mx-2">/</span>
        <span>대표 인사말</span>
      </div>
      <h1 class="text-4xl font-black">대표 인사말</h1>
    </div>
  </section>

  <!-- Greeting -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid lg:grid-cols-5 gap-12 items-start">
        <!-- Photo -->
        <div class="lg:col-span-2">
          <img src={url("/profile.jpg")} alt="정성우 노무사" class="w-full rounded-3xl shadow-lg" />
          <div class="mt-6 bg-gray-50 rounded-2xl p-6 space-y-3 text-sm">
            <h3 class="font-bold text-navy-900 mb-4">주요 이력</h3>
            {[
              '現 하온 노동법률사무소 대표 공인노무사',
              '前 노무법인 더보상 부산경남지사',
              '前 노무법인 더보상 경북구미지사',
              '창원지방법원 민사조정위원 (2025.12.1.~2027.3.31.)',
              '안전보건관리체계 구축 컨설팅 실무교육 수료',
              '부산대학교 사회학과 졸업',
            ].map((item) => (
              <div class="flex items-center gap-2 text-gray-600">
                <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </div>
            ))}
          </div>
        </div>

        <!-- Message -->
        <div class="lg:col-span-3">
          <p class="text-gold-500 font-semibold text-sm uppercase tracking-wider mb-3">Greeting</p>
          <h2 class="text-3xl font-black text-navy-900 leading-snug mb-8">
            아픈 몸으로 홀로 싸우지<br />않아도 됩니다
          </h2>
          <div class="prose prose-gray max-w-none space-y-5 text-gray-600 leading-loose text-[15px]">
            <p>
              안녕하십니까, 하온 노동법률사무소 대표 공인노무사 정성우입니다.
            </p>
            <p>
              예기치 못한 산업재해로 고통받는 재해자분들의 막막함과 아픔에 깊이 공감합니다.
            </p>
            <p>
              저희 하온 노동법률사무소는 산재 분야에 특화된 전문성과 축적된 노하우를 바탕으로, 복잡한 의학적·법리적 쟁점을 명확히 입증하여 여러분의 정당한 권리를 찾아드립니다.
            </p>
            <p>
              저는 근골격계, 소음성난청, 직업성 암, 뇌심혈관, 폐질환 등등 다양한 산업재해 분야에서 1,000 건 이상의 사건을 직접 경험하며 수많은 분들의 산재 승인을 이끌어냈습니다.
            </p>
            <p>
              저희는 '하'늘 아래 모든 분들이 '온'전한 권리를 누릴 수 있도록 돕자는 마음으로, 한 분 한 분의 사례를 내 가족의 일처럼 생각하고 임합니다. 처음 상담부터 보상 수령까지, 하온 노동법률사무소가 함께하겠습니다.
            </p>
            <p class="font-semibold text-navy-900">
              하온 노동법률사무소 대표 공인노무사<br />
              <span class="text-2xl font-black">정성우</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-navy-900 text-white text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-black mb-4">지금 무료로 상담하세요</h2>
      <p class="text-gray-300 mb-8">상담 후 산재 가능성이 없을 경우 어떠한 비용도 청구하지 않습니다</p>
      <a href={url("/consulting")} class="inline-block px-10 py-4 bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold rounded-xl transition-colors">
        무료상담 신청하기
      </a>
    </div>
  </section>
</Layout>
