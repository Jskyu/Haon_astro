---
import Layout from '../../layouts/Layout.astro';
import { url } from '../../utils/url';
---

<Layout title="직업성 암 산재 가이드" description="직업성 암 산재 신청 - 방광암, 폐암, 백혈병, 중피종 - 하온 노동법률사무소">

  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-sm text-gold-400 mb-2">
        <a href={url("/")} class="hover:underline">홈</a>
        <span class="mx-2">/</span>
        <a href={url("/specialty")} class="hover:underline">전문 분야</a>
        <span class="mx-2">/</span>
        <span>직업성 암</span>
      </div>
      <h1 class="text-4xl font-black">직업성 암</h1>
      <p class="mt-3 text-gray-300 max-w-2xl">
        발암물질 노출로 인한 암은 직업성 암으로 산재 보상을 받을 수 있습니다. 퇴직 후 발병해도 적용됩니다.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">

      <div class="mb-12">
        <h2 class="text-2xl font-black text-navy-900 mb-4">직업성 암이란?</h2>
        <p class="text-gray-600 leading-loose mb-4">
          업무 중 발암물질에 노출되어 발생하는 암을 직업성 암이라 합니다.
          국제암연구소(IARC) 분류 1군 발암물질 노출력이 있고, 해당 발암물질과 인과관계가 인정되는 암종이면 산재 인정이 가능합니다.
        </p>
        <p class="text-gray-600 leading-loose">
          암은 잠복기가 10~30년에 달하므로, 퇴직 후 발병한 경우에도 과거 업무 이력을 통해 인과관계를 입증할 수 있습니다.
        </p>
      </div>

      <!-- Cancer types -->
      <div class="mb-12">
        <h2 class="text-2xl font-black text-navy-900 mb-6">주요 직업성 암 유형</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-navy-900 text-white">
                <th class="px-4 py-3 text-left rounded-tl-xl">암 종류</th>
                <th class="px-4 py-3 text-left">주요 발암물질</th>
                <th class="px-4 py-3 text-left rounded-tr-xl">관련 업종</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['중피종', '석면', '조선업, 건설업, 단열재 시공'],
                ['폐암', '석면, 라돈, 크롬, 니켈', '광업, 용접, 도금'],
                ['방광암', '방향족 아민, 벤지딘', '염료, 고무, 가죽 제조'],
                ['백혈병', '벤젠, 방사선', '페인트, 인쇄, 석유화학'],
                ['간암', '비닐클로라이드', '플라스틱, PVC 제조'],
                ['비강·부비동암', '목분, 가죽 분진', '가구, 신발 제조'],
                ['피부암', '다환방향족탄화수소(PAH)', '아스팔트, 코크스 공장'],
                ['갑상선암', '방사선', '원전, 의료 방사선 종사자'],
              ].map(([cancer, agent, industry], i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                  <td class="px-4 py-3 font-semibold text-navy-900 border border-gray-100">{cancer}</td>
                  <td class="px-4 py-3 text-gray-600 border border-gray-100">{agent}</td>
                  <td class="px-4 py-3 text-gray-500 border border-gray-100">{industry}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Key points -->
      <div class="mb-12">
        <h2 class="text-2xl font-black text-navy-900 mb-6">산재 인정의 핵심</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            {
              title: '노출 이력 입증',
              desc: '발암물질에 노출된 구체적 근거. 작업환경 측정 결과, 물질안전보건자료(MSDS), 동료 진술 등이 활용됩니다.',
            },
            {
              title: '노출 기간 및 강도',
              desc: '짧은 기간의 노출도 인정되나, 일반적으로 수년 이상 지속적·반복적 노출이 인과관계 입증에 유리합니다.',
            },
            {
              title: '역학적 관련성',
              desc: 'IARC 분류, 국내외 역학 연구를 활용해 해당 발암물질과 암 종류 사이의 과학적 연관성을 제시합니다.',
            },
            {
              title: '다른 원인 배제',
              desc: '흡연, 음주, 가족력 등 다른 원인이 있어도 업무 기여도가 인정되면 산재 인정이 가능합니다.',
            },
          ].map((item) => (
            <div class="bg-blue-50 rounded-xl p-5">
              <h3 class="font-bold text-blue-900 mb-2 text-sm">{item.title}</h3>
              <p class="text-sm text-blue-800 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mb-12">
        <h3 class="font-bold text-amber-900 mb-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="inline mr-1.5 -mt-0.5" viewBox="0 0 16 16"><path d="M7.938 2.016A.13.13 0 0 1 8.002 2a.13.13 0 0 1 .063.016.15.15 0 0 1 .054.057l6.857 11.667c.036.06.035.124.002.183a.2.2 0 0 1-.054.06.1.1 0 0 1-.066.017H1.146a.1.1 0 0 1-.066-.017.2.2 0 0 1-.054-.06.18.18 0 0 1 .002-.183L7.884 2.073a.15.15 0 0 1 .054-.057zm1.044-.45a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767z"/><path d="M7.002 12a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 5.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/></svg> 소멸시효에 주의하세요</h3>
        <p class="text-sm text-amber-800 leading-relaxed">
          요양급여는 <strong>진단일로부터 3년</strong>, 장해급여는 <strong>치료 종결 후 5년</strong>이 소멸시효입니다.
          암 진단을 받은 즉시 산재 가능성을 검토하는 것이 중요합니다.
        </p>
      </div>

      <div class="bg-navy-900 rounded-2xl p-8 text-center text-white">
        <h2 class="text-2xl font-black mb-3">직업성 암 무료 상담</h2>
        <p class="text-gray-300 text-sm mb-6">암 진단명, 과거 직업 이력을 말씀해 주시면 즉시 검토해드립니다.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={url("/consulting")} class="px-8 py-3.5 bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold rounded-xl transition-colors">온라인 상담 신청</a>
          <a href="tel:050713281579" class="px-8 py-3.5 border border-white/30 hover:bg-white/10 font-semibold rounded-xl transition-colors">0507-1328-1579</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
