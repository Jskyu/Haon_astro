---
import Layout from '../../layouts/Layout.astro';
import { url } from '../../utils/url';
---

<Layout title="유족보상 산재 가이드" description="산재 사망 시 유족보상 - 유족급여, 장의비, 유족연금 신청 방법 - 하온 노무사 사무소">

  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-sm text-gold-400 mb-2">
        <a href={url("/")} class="hover:underline">홈</a>
        <span class="mx-2">/</span>
        <a href={url("/specialty")} class="hover:underline">전문 분야</a>
        <span class="mx-2">/</span>
        <span>유족보상</span>
      </div>
      <div class="inline-block bg-gold-500 text-navy-900 text-xs font-bold px-3 py-1 rounded-full mb-4">🏠 산재 가이드</div>
      <h1 class="text-4xl font-black">유족보상</h1>
      <p class="mt-3 text-gray-300 max-w-2xl">
        사랑하는 가족을 잃으셨나요? 업무 관련 사망이라면 유족보상연금을 받을 수 있습니다. 저희가 함께하겠습니다.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">

      <div class="mb-12">
        <h2 class="text-2xl font-black text-navy-900 mb-4">유족보상이란?</h2>
        <p class="text-gray-600 leading-loose mb-4">
          업무상 재해(사고 또는 질병)로 사망한 경우, 유족에게 유족급여와 장의비를 지급하는 제도입니다.
          유족급여는 <strong class="text-navy-900">유족보상연금</strong> 또는 <strong class="text-navy-900">유족보상일시금</strong> 중 선택할 수 있습니다.
        </p>
        <p class="text-gray-600 leading-loose">
          사고사(작업 중 사망)뿐만 아니라 <strong>직업성 질병(암, 심뇌혈관, 진폐 등)으로 인한 사망</strong>도 해당됩니다.
          직업성 질병으로 인한 사망은 퇴직 이후에 발병·사망한 경우에도 산재 신청이 가능합니다.
        </p>
      </div>

      <!-- Benefits -->
      <div class="mb-12">
        <h2 class="text-2xl font-black text-navy-900 mb-6">지급되는 보상 내용</h2>
        <div class="space-y-4">
          {[
            {
              title: '유족보상연금',
              badge: '선택',
              desc: '매년 평균임금의 52~67%를 연금으로 지급. 유족 수에 따라 금액 차등.',
              details: ['수급권자: 배우자, 자녀, 부모, 손자녀, 조부모 등', '수급자격 상실 시(재혼 등) 연금 지급 종료', '가족 수에 따라 연금액 가산 (1인당 5%)'],
            },
            {
              title: '유족보상일시금',
              badge: '선택',
              desc: '평균임금의 1,300일치 일시 지급. 수급 자격자가 없거나 연금 미선택 시.',
              details: ['연금과 달리 한 번에 수령', '유족 중 선순위자 전액 수령', '연금 선택 후 포기 불가능'],
            },
            {
              title: '장의비',
              badge: '필수',
              desc: '장제에 소요되는 비용 지원. 평균임금의 120일치 또는 최고·최저 금액 내.',
              details: ['업무상 사망 확인 즉시 청구 가능', '장례 진행 전 산재 승인 여부 확인 권장', '실제 장례비용과 무관하게 정액 지급'],
            },
          ].map((b) => (
            <div class="bg-gray-50 rounded-2xl p-6">
              <div class="flex items-center gap-3 mb-3">
                <h3 class="font-bold text-navy-900">{b.title}</h3>
                <span class="text-xs bg-navy-900 text-gold-400 px-2.5 py-0.5 rounded-full font-medium">{b.badge}</span>
              </div>
              <p class="text-sm text-gray-600 mb-4">{b.desc}</p>
              <ul class="space-y-1.5">
                {b.details.map((d) => (
                  <li class="flex items-start gap-2 text-sm text-gray-500">
                    <svg class="w-4 h-4 text-blue-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {d}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Priority -->
      <div class="mb-12">
        <h2 class="text-2xl font-black text-navy-900 mb-5">수급권자 우선순위</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-navy-900 text-white">
                <th class="px-4 py-3 text-left rounded-tl-xl">순위</th>
                <th class="px-4 py-3 text-left">대상</th>
                <th class="px-4 py-3 text-left rounded-tr-xl">요건</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['1순위', '배우자', '사망 당시 혼인관계 유지 (사실혼 포함)'],
                ['2순위', '자녀', '25세 미만 또는 장애 자녀'],
                ['3순위', '부모', '60세 이상 또는 장애 부모'],
                ['4순위', '손자녀', '25세 미만 또는 장애 손자녀'],
                ['5순위', '조부모', '60세 이상 또는 장애 조부모'],
                ['6순위', '형제자매', '19세 미만 또는 60세 이상, 장애인'],
              ].map(([rank, target, req], i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                  <td class="px-4 py-3 font-bold text-blue-700 border border-gray-100">{rank}</td>
                  <td class="px-4 py-3 font-semibold text-navy-900 border border-gray-100">{target}</td>
                  <td class="px-4 py-3 text-gray-600 border border-gray-100">{req}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-2xl p-6 mb-12">
        <h3 class="font-bold text-blue-900 mb-2">유족보상 청구 소멸시효: 5년</h3>
        <p class="text-sm text-blue-800 leading-relaxed">
          유족보상은 <strong>사망일로부터 5년</strong>이 소멸시효입니다. 가족이 돌아가신 후 시간이 지났더라도 5년 내라면 신청 가능합니다. 지금 바로 확인하세요.
        </p>
      </div>

      <div class="bg-navy-900 rounded-2xl p-8 text-center text-white">
        <h2 class="text-2xl font-black mb-3">유족보상 무료 상담</h2>
        <p class="text-gray-300 text-sm mb-6">고인의 직업력과 사망 경위를 말씀해 주시면 신청 가능 여부를 즉시 검토해드립니다.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={url("/consulting")} class="px-8 py-3.5 bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold rounded-xl transition-colors">온라인 상담 신청</a>
          <a href="tel:01023151579" class="px-8 py-3.5 border border-white/30 hover:bg-white/10 font-semibold rounded-xl transition-colors">010-2315-1579</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
