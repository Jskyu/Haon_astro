---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="근골격계 질환 산재 가이드" description="근골격계 질환 산재 신청 방법 - 요추 추간판, 어깨, 손목, 무릎 등 - 하온 노무사 사무소">

  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-sm text-gold-400 mb-2">
        <a href="/" class="hover:underline">홈</a>
        <span class="mx-2">/</span>
        <a href="/specialty" class="hover:underline">전문 분야</a>
        <span class="mx-2">/</span>
        <span>근골격계 질환</span>
      </div>
      <div class="inline-block bg-gold-500 text-navy-900 text-xs font-bold px-3 py-1 rounded-full mb-4">🦴 산재 가이드</div>
      <h1 class="text-4xl font-black">근골격계 질환</h1>
      <p class="mt-3 text-gray-300 max-w-2xl">
        반복 작업, 무거운 중량물 취급, 불편한 자세로 인한 허리·어깨·손목 질환은 산재로 인정받을 수 있습니다.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">

      <div class="mb-12">
        <h2 class="text-2xl font-black text-navy-900 mb-4">근골격계 직업병이란?</h2>
        <p class="text-gray-600 leading-loose mb-4">
          근골격계 질환(Musculoskeletal Disorders)은 근육, 뼈, 관절, 인대, 건 등에 발생하는 직업성 질환입니다.
          과도한 힘, 반복적 동작, 부적절한 작업 자세, 진동, 접촉 스트레스가 주요 원인입니다.
        </p>
        <p class="text-gray-600 leading-loose">
          산재보험법상 <strong class="text-navy-900">업무와 질병 사이의 상당인과관계</strong>가 인정되면 요양급여를 받을 수 있으며,
          단순 업무상 사고와 달리 직업성 질환으로 처리됩니다.
        </p>
      </div>

      <!-- Disease types -->
      <div class="mb-12">
        <h2 class="text-2xl font-black text-navy-900 mb-6">주요 질환 유형</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { title: '요추 추간판 탈출증 (허리디스크)', desc: '중량물 취급, 반복 허리 굴곡 작업. 요추 4-5번, 5번-천추 1번 호발', tags: ['택배', '간호사', '건설업'] },
            { title: '회전근개 파열', desc: '반복적 어깨 사용, 두팔 들기 작업. 어깨 통증, 팔 들기 불가', tags: ['용접', '도배', '간호사'] },
            { title: '수근관 증후군', desc: '손목 반복 굴곡·신전. 야간 저림, 엄지-중지 감각 이상', tags: ['조리사', '컴퓨터 작업', '생산직'] },
            { title: '경추 추간판 탈출증', desc: '목 고정 자세, 고개 숙인 작업. 목·팔 통증, 저림', tags: ['사무직', '반도체', '봉제'] },
            { title: '슬관절 질환', desc: '무릎 꿇기, 쪼그려 앉기 반복 작업. 반월상 연골 손상', tags: ['배관공', '바닥 작업', '광부'] },
            { title: '건염·건초염', desc: '반복적인 손·손목 사용으로 인한 건 염증', tags: ['식품 가공', '조립 작업', '포장'] },
          ].map((d) => (
            <div class="bg-gray-50 rounded-2xl p-5">
              <h3 class="font-bold text-navy-900 mb-2 text-sm">{d.title}</h3>
              <p class="text-sm text-gray-600 mb-3">{d.desc}</p>
              <div class="flex flex-wrap gap-1.5">
                {d.tags.map((tag) => (
                  <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Recognition criteria -->
      <div class="mb-12">
        <h2 class="text-2xl font-black text-navy-900 mb-6">산재 인정 핵심 요건</h2>
        <div class="space-y-4">
          {[
            {
              title: '업무 관련성 (인과관계)',
              desc: '질환 발생 또는 악화가 업무로 인한 것임을 의학적·역학적으로 입증해야 합니다. 작업 자세, 작업 강도, 노출 기간이 핵심입니다.',
            },
            {
              title: '작업 요인 노출',
              desc: '반복 동작(분당 반복 횟수), 중량물(kg 단위), 부자연스러운 자세(측정 도구 활용) 등이 구체적으로 확인되어야 합니다.',
            },
            {
              title: '기존 질환과의 구분',
              desc: '퇴행성 변화가 있더라도 업무로 인해 자연경과 이상으로 악화된 경우 산재 인정 가능합니다.',
            },
          ].map((item) => (
            <div class="flex gap-4 p-5 border border-gray-100 rounded-xl">
              <div class="w-2 bg-blue-500 rounded-full shrink-0"></div>
              <div>
                <h3 class="font-bold text-navy-900 mb-1">{item.title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Needed docs -->
      <div class="mb-12 bg-blue-50 rounded-2xl p-6">
        <h2 class="text-lg font-bold text-blue-900 mb-4">준비 서류</h2>
        <div class="grid sm:grid-cols-2 gap-4 text-sm text-blue-800">
          <div>
            <p class="font-semibold mb-2">의료 관련</p>
            <ul class="space-y-1.5">
              {['진단서 및 소견서', 'MRI·X-ray 영상 자료', '진료 기록 사본', '수술 기록지 (해당 시)'].map((i) => (
                <li class="flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {i}
                </li>
              ))}
            </ul>
          </div>
          <div>
            <p class="font-semibold mb-2">업무 관련</p>
            <ul class="space-y-1.5">
              {['재직증명서·고용계약서', '작업 내용 상세 기술서', '근무 시간 기록', '동료·상급자 진술서', '작업환경 측정 결과'].map((i) => (
                <li class="flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {i}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="bg-navy-900 rounded-2xl p-8 text-center text-white">
        <h2 class="text-2xl font-black mb-3">근골격계 질환 무료 상담</h2>
        <p class="text-gray-300 text-sm mb-6">직종, 작업 내용, 질환명을 말씀해 주시면 산재 가능성을 바로 검토해 드립니다.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/consulting" class="px-8 py-3.5 bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold rounded-xl transition-colors">온라인 상담 신청</a>
          <a href="tel:0212345678" class="px-8 py-3.5 border border-white/30 hover:bg-white/10 font-semibold rounded-xl transition-colors">02-1234-5678</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
