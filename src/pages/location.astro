      center: new naver.maps.LatLng(37.4985, 127.0278), // 역삼역 인근
      zoom: 16,
    });

    const marker = new naver.maps.Marker({
      position: new naver.maps.LatLng(37.4985, 127.0278),
      map,
    });

    const infoWindow = new naver.maps.InfoWindow({
      content: '<div style="padding:10px;font-size:13px;font-weight:bold;">하온 노무사 사무소</div>',
    });
