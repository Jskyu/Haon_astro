---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/url';
---

<Layout title="오시는 길" description="하온 노무사 사무소 오시는 길 - 부산 북구 백암대로 위치, 네이버 지도">

  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-sm text-gold-400 mb-2">
        <a href={url("/")} class="hover:underline">홈</a>
        <span class="mx-2">/</span>
        <span>오시는 길</span>
      </div>
      <h1 class="text-4xl font-black">오시는 길</h1>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12">

        <!-- Map -->
        <div>
          <h2 class="text-xl font-bold text-navy-900 mb-4">사무소 위치</h2>

          <!-- Naver Map embed -->
          <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm" id="map-wrapper">
            <!-- 네이버 지도 API 키 발급 후 아래 스크립트 연동 필요 -->
            <div id="naver-map" class="w-full h-96 bg-gradient-to-br from-blue-50 to-green-50 flex flex-col items-center justify-center gap-4">
              <svg class="w-12 h-12 text-green-500" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <div class="text-center">
                <p class="text-gray-600 font-medium">부산 북구 백암대로 1167-1</p>
                <p class="text-gray-400 text-sm">2층</p>
              </div>
              <a
                href="https://map.naver.com/p/search/부산 북구 백암대로 1167-1"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white px-6 py-2.5 rounded-lg font-medium transition-colors text-sm"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
                네이버 지도에서 보기
              </a>
            </div>
          </div>

          <!-- 네이버 지도 JavaScript API 연동 안내 -->
          <!-- ncpKeyId 발급: https://console.ncloud.com/ -->
          <p class="text-xs text-gray-400 mt-2 text-center">
            * 네이버 클라우드 플랫폼 API 키 설정 후 실제 지도로 교체됩니다
          </p>
        </div>

        <!-- Info -->
        <div class="space-y-8">
          <div>
            <h2 class="text-xl font-bold text-navy-900 mb-5">사무소 안내</h2>
            <div class="space-y-4">
              {[
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
                  label: '주소',
                  value: '부산 북구 백암대로 1167-1, 2층',
                },
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>`,
                  label: '전화',
                  value: '010-2315-1579',
                  href: 'tel:01023151579',
                },
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>`,
                  label: '팩스',
                  value: '051-719-9608',
                },
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
                  label: '이메일',
                  value: 'jswcpla@gmail.com',
                },
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
                  label: '운영 시간',
                  value: '평일 09:00 – 18:00\n토요일 09:00 – 13:00\n일·공휴일 휴무',
                },
              ].map((item) => (
                <div class="flex gap-4 p-4 bg-gray-50 rounded-xl">
                  <div class="text-blue-600 mt-0.5 shrink-0" set:html={item.icon} />
                  <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">{item.label}</p>
                    {item.href ? (
                      <a href={item.href} class="text-sm text-gray-700 font-medium hover:text-blue-600 transition-colors whitespace-pre-line">
                        {item.value}
                      </a>
                    ) : (
                      <p class="text-sm text-gray-700 font-medium whitespace-pre-line">{item.value}</p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Transport -->
          <div>
            <h3 class="font-bold text-navy-900 mb-4">찾아오시는 방법</h3>
            <div class="space-y-3">
              {[
                {
                  type: '지하철',
                  icon: '🚇',
                  desc: '부산도시철도 3호선 구포역 → 버스·택시 환승',
                },
                {
                  type: '버스',
                  icon: '🚌',
                  desc: '백암대로 정류장 하차',
                },
                {
                  type: '자가용',
                  icon: '🚗',
                  desc: '건물 앞 주차 가능',
                },
                {
                  type: '택시',
                  icon: '🚕',
                  desc: '"부산 북구 백암대로 1167-1" 으로 요청',
                },
              ].map((t) => (
                <div class="flex items-start gap-3 text-sm">
                  <span class="text-base">{t.icon}</span>
                  <div>
                    <span class="font-semibold text-navy-900">{t.type}</span>
                    <span class="text-gray-500 ml-2">{t.desc}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <a href={url("/consulting")} class="flex items-center justify-center gap-2 w-full py-4 bg-navy-900 hover:bg-navy-800 text-white font-bold rounded-xl transition-colors">
            방문 전 무료상담 신청하기
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // 네이버 지도 JavaScript API 연동 예시
  // ncpKeyId를 발급받은 후 아래 코드를 활성화하세요.
  // https://console.ncloud.com/ > AI·NAVER API > Maps > Web Dynamic Map

  /*
