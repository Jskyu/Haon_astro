---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/url';
---

<Layout
  title="오시는 길"
  description="하온 노동법률사무소 오시는 길 - 부산 북구 백양대로 위치, 네이버 지도"
  keywords="하온노동법률사무소위치, 부산노무사위치, 부산북구노무사, 산재상담장소, 오시는길"
>

  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-sm text-gold-400 mb-2">
        <a href={url("/")} class="hover:underline">홈</a>
        <span class="mx-2">/</span>
        <span>오시는 길</span>
      </div>
      <h1 class="text-4xl font-black">오시는 길</h1>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12">

        <!-- Map -->
        <div>
          <h2 class="text-xl font-bold text-navy-900 mb-4">사무소 위치</h2>

          <!-- Naver Map -->
          <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
            <div id="naver-map" class="w-full h-96"></div>
          </div>

          <div class="mt-4 text-center">
            <a
              href="https://map.naver.com/p/search/부산%20북구%20백양대로%201167-1"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-lg font-medium transition-colors text-sm"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              네이버 지도 크게 보기
            </a>
          </div>
        </div>

        <!-- Info -->
        <div class="space-y-8">
          <div>
            <h2 class="text-xl font-bold text-navy-900 mb-5">사무소 안내</h2>
            <div class="space-y-4">
              {[
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
                  label: '주소',
                  value: '부산 북구 백양대로 1167-1, 2층',
                },
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>`,
                  label: '전화',
                  value: '0507-1328-1579',
                  href: 'tel:050713281579',
                },
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>`,
                  label: '팩스',
                  value: '051-719-9608',
                },
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
                  label: '이메일',
                  value: 'jswcpla@gmail.com',
                },
                {
                  icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
                  label: '운영 시간',
                  value: '평일 09:00 – 18:00\n(토·일·공휴일 휴무)',
                },
              ].map((item) => (
                <div class="flex gap-4 p-4 bg-gray-50 rounded-xl">
                  <div class="text-blue-600 mt-0.5 shrink-0" set:html={item.icon} />
                  <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">{item.label}</p>
                    {item.href ? (
                      <a href={item.href} class="text-sm text-gray-700 font-medium hover:text-blue-600 transition-colors whitespace-pre-line">
                        {item.value}
                      </a>
                    ) : (
                      <p class="text-sm text-gray-700 font-medium whitespace-pre-line">{item.value}</p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <a href={url("/consulting")} class="flex items-center justify-center gap-2 w-full py-4 bg-navy-900 hover:bg-navy-800 text-white font-bold rounded-xl transition-colors">
            방문 전 무료상담 신청하기
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  // 네이버 지도 API 로드 및 초기화
  (function() {
    const script = document.createElement('script');
    script.type = 'text/javascript';
    script.src = 'https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=8d533iudy3';
    script.onload = function() {
      // 하온 노동법률사무소 좌표
      const position = new naver.maps.LatLng(35.2065912, 129.0044803);

      // 지도 생성
      const map = new naver.maps.Map('naver-map', {
        center: position,
        zoom: 17,
        zoomControl: true,
        zoomControlOptions: {
          position: naver.maps.Position.TOP_RIGHT
        },
        mapTypeControl: true,
        mapTypeControlOptions: {
          position: naver.maps.Position.TOP_LEFT
        }
      });

      // 마커 생성
      const marker = new naver.maps.Marker({
        position: position,
        map: map,
        title: '하온 노동법률사무소',
        icon: {
          content: [
            '<div style="position:relative;">',
            '<div style="width:30px;height:40px;background:url(\'data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 32%22%3E%3Cpath fill=%22%231e3a8a%22 d=%22M12,0 C5.4,0 0,5.4 0,12 C0,18 12,32 12,32 S24,18 24,12 C24,5.4 18.6,0 12,0 Z M12,16 C9.8,16 8,14.2 8,12 C8,9.8 9.8,8 12,8 C14.2,8 16,9.8 16,12 C16,14.2 14.2,16 12,16 Z%22/%3E%3C/svg%3E\') center/contain no-repeat;"/>',
            '<div style="position:absolute;top:45px;left:50%;transform:translateX(-50%);background-color:#1e3a8a;color:white;padding:6px 10px;border-radius:12px;font-weight:bold;font-size:11px;box-shadow:0 2px 8px rgba(0,0,0,0.25);white-space:nowrap;">하온 노동법률사무소</div>',
            '</div>'
          ].join(''),
          anchor: new naver.maps.Point(15, 40)
        }
      });
    };

    script.onerror = function() {
      console.error('네이버 지도 API 로드 실패');
      const mapEl = document.getElementById('naver-map');
      if (mapEl) {
        mapEl.innerHTML = `
          <div class="flex items-center justify-center h-full bg-gray-100">
            <div class="text-center p-6">
              <p class="text-gray-600 mb-4">지도를 불러올 수 없습니다.</p>
              <a href="https://map.naver.com/p/search/부산%20북구%20백양대로%201167-1"
                 target="_blank"
                 rel="noopener noreferrer"
                 class="inline-block bg-green-500 text-white px-6 py-2 rounded-lg hover:bg-green-600">
                네이버 지도에서 보기
              </a>
            </div>
          </div>
        `;
      }
    };

    document.head.appendChild(script);
  })();
</script>
