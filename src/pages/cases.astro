---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/url';

const cases = [
  {
    category: '근골격계',
    title: '건설업 15년 근무 형틀목공',
    company: '건설업 / 남성',
    result: '산재 승인',
    amount: '92,927,290원',
    desc: '"나이가 들어서 그렇겠지"라며 주저하셨으나, 의학적·법리적 쟁점 분석 및 인과관계 입증하여 산재 승인',
    point: '장해급여 92,927,290원 수령',
  },
  {
    category: '뇌심혈관',
    title: '화물차 기사 급성심근경색',
    company: '운송업 / 남성',
    result: '유족급여 인정',
    amount: '유족급여+장례비 114,648,590원 + 매月 연금',
    desc: '지병(고혈압)이 있으셨으나, 과로와 업무부담 가중요인 주장하여 산재 유족급여 인정',
    point: '유족급여+장례비 114,648,590원 + 매月 연금 수령',
  },
  {
    category: '직업성 암',
    title: '자동차 공업사 근로자 폐암',
    company: '자동차 정비업 / 남성',
    result: '산재 승인',
    amount: '61,590,320원 등',
    desc: '업무 내용·근무환경 정리, 직업환경연구원 자료 및 산업안전보건공단 자료 등 제출하여 업무 중 발암물질 노출 입증을 통해 폐암 승인',
    point: '병원비, 휴업급여 61,590,320원 등 수령',
  },
  {
    category: '근골격계',
    title: '건설 근로자 어깨 회전근개 파열',
    company: '건설업 / 남성',
    result: '산재 승인',
    amount: '95,447,910원',
    desc: '장기간 건설 현장 근무로 인한 어깨 회전근개 파열. 수술 및 재활치료 진행',
    point: '수술비 전액 산재 처리, 장해급여 95,447,910원 수령',
  },
  {
    category: '소음성 난청',
    title: '중공업 사상 작업자 소음성 난청',
    company: '중공업 / 남성',
    result: '산재 승인',
    amount: '69,101,200원',
    desc: '30년 이상 그라인더 사상 작업으로 인한 소음성 난청. 장기간 85dB 이상 소음 노출 환경에서 근무',
    point: '장해급여 69,101,200원 수령',
  },
  {
    category: '직업성 암',
    title: '형틀목공 40년 폐암',
    company: '건설업 / 남성',
    result: '산재 승인',
    amount: '병원비 및 장해급여',
    desc: '40년간 형틀목공 작업 중 결정형 유리규산 노출로 인한 폐암 발병. 건설근로자공제회, 고용보험, 국민연금 등 자료를 활용하여 장기 근무 입증',
    point: '결정형 유리규산 노출 입증을 통한 직업성 폐암 인정',
  },
  {
    category: '근골격계',
    title: '건설업 재요양 및 추가상병 승인',
    company: '건설업 / 남성',
    result: '재요양 승인',
    amount: '철심제거술, 인공관절수술 등',
    desc: '산재 종결 후 재요양 및 추가상병 신청. 철심제거수술, 인공관절수술 등 추가 치료 필요',
