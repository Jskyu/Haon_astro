  },
];
---

<Layout title="성공사례" description="하온 노동법률사무소 산재 성공사례 - 소음성 난청, 심뇌혈관, 근골격계, 직업성 암, 출퇴근재해">

  <!-- 페이지 헤더 -->
  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-sm text-gold-400 mb-2">
        <a href={url("/")} class="hover:underline">홈</a>
        <span class="mx-2">/</span>
        <span>성공사례</span>
      </div>
      <h1 class="text-4xl font-black">성공사례</h1>
      <p class="mt-3 text-gray-300 max-w-xl">
        실제 사례를 통해 하온 노동법률사무소의 전문성을 확인하세요. 개인정보 보호를 위해 일부 내용은 변경하였습니다.
      </p>
      <a href="https://blog.naver.com/jswcpla/224054356423" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-5 px-6 py-3 bg-white/10 hover:bg-white/20 border border-white/30 text-white rounded-lg transition-colors text-sm font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        블로그에서 더 많은 사례 보기
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Cases grid -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {cases.map((c) => (
          <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-md transition-shadow">
            <div class="bg-navy-900 px-5 py-3 flex items-center justify-between">
              <span class="text-xs font-bold text-gold-400 tracking-wider">{c.category}</span>
              <span class="text-xs font-semibold text-white/70 flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {c.result}
              </span>
            </div>
            <div class="p-6">
              <h3 class="font-bold text-navy-900 text-base mb-1">{c.title}</h3>
              <p class="text-xs text-gray-400 mb-4">{c.company}</p>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">{c.desc}</p>
              <div class="bg-stone-50 rounded-xl p-3.5 mb-4">
                <p class="text-xs text-stone-600 font-medium">{c.point}</p>
              </div>
              <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                <span class="text-xs text-gray-400">수령 금액</span>
                <span class="text-base font-black text-gold-600">{c.amount}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 bg-navy-900 text-center text-white">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-black mb-3">나도 산재 신청이 가능할까요?</h2>
      <p class="text-gray-300 mb-8 text-sm">불승인을 받으셨어도 포기하지 마세요. 함께 다시 검토해드립니다.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={url("/consulting")} class="inline-block px-10 py-4 bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold rounded-xl transition-colors">
          무료상담 신청
        </a>
        <a href="https://blog.naver.com/jswcpla/224054356423" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-white/30 hover:border-gold-400 text-white hover:text-gold-400 font-bold rounded-xl transition-colors">
          블로그에서 더 많은 사례 보기
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
