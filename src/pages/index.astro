---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/url';
---

<Layout>

  <!-- Hero -->
  <section class="bg-navy-900 text-white">
    <div class="max-w-6xl mx-auto px-4 py-24 md:py-36">
      <div class="max-w-2xl">
        <p class="text-gold-400 text-sm font-semibold tracking-widest mb-5 uppercase">산재 전문 공인노무사</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6">
          <span class="block lg:whitespace-nowrap"><span class="text-gold-400">하</span>늘아래 모든 분들이</span>
          <span class="block lg:whitespace-nowrap"><span class="text-gold-400">온</span>전한 행복을 누릴 수 있도록</span>
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-10 max-w-xl">
          산업재해, 업무상질병 등 복잡한 산재 신청부터 평균임금 정정, 불승인 이의제기까지.<br class="sm:hidden" />
          하온 노동법률사무소가 끝까지 함께합니다.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={url('/consulting')} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold text-base rounded-xl transition-colors">
            무료상담 신청하기
          </a>
          <a href="tel:050713281579" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/30 hover:bg-white/10 text-white font-semibold text-base rounded-xl transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            0507-1328-1579
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-12">
        <p class="text-gold-600 font-semibold text-sm tracking-widest uppercase mb-2">전문 서비스</p>
        <h2 class="text-3xl md:text-4xl font-black text-navy-900">산재 유형별 전문 대응</h2>
        <p class="mt-4 text-gray-500 max-w-xl">업종과 질병 유형에 따라 최적화된 전략으로 승인을 이끌어냅니다</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-gray-200">
        {[
          {
            title: '소음성 난청',
            desc: '오랜 소음 노출로 인한 직업성 청력손실 산재 처리',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 16 16"><path d="M8.5 1A4.5 4.5 0 0 0 4 5.5v7.047a2.453 2.453 0 0 0 4.75.861l.512-1.363a5.6 5.6 0 0 1 .816-1.46l2.008-2.581A4.34 4.34 0 0 0 8.66 1zM3 5.5A5.5 5.5 0 0 1 8.5 0h.16a5.34 5.34 0 0 1 4.215 8.618l-2.008 2.581a4.6 4.6 0 0 0-.67 1.197l-.51 1.363A3.453 3.453 0 0 1 3 12.547zM8.5 4A1.5 1.5 0 0 0 7 5.5v2.695q.168-.09.332-.192c.327-.208.577-.44.72-.727a.5.5 0 1 1 .895.448c-.256.513-.673.865-1.079 1.123A9 9 0 0 1 7 9.313V11.5a.5.5 0 0 1-1 0v-6a2.5 2.5 0 0 1 5 0V6a.5.5 0 0 1-1 0v-.5A1.5 1.5 0 0 0 8.5 4"/></svg>`,
          },
          {
            title: '근골격계 질환',
            desc: '인공관절 수술, 허리디스크, 어깨, 손목 등 산재 처리',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 16 16"><path d="M8 3a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3"/><path d="m5.93 6.704-.846 8.451a.768.768 0 0 0 1.523.203l.81-4.865a.59.59 0 0 1 1.165 0l.81 4.865a.768.768 0 0 0 1.523-.203l-.845-8.451A1.5 1.5 0 0 1 10.5 5.5L13 2.284a.796.796 0 0 0-1.239-.998L9.634 3.84a.7.7 0 0 1-.33.235c-.23.074-.665.176-1.304.176-.64 0-1.074-.102-1.305-.176a.7.7 0 0 1-.329-.235L4.239 1.286a.796.796 0 0 0-1.24.998l2.5 3.216c.317.316.475.758.43 1.204Z"/></svg>`,
          },
          {
            title: '뇌심혈관 질환',
            desc: '과로·스트레스로 인한 뇌출혈, 급성심근경색 등',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 16 16"><path d="m8 2.748-.717-.737C5.6.281 2.514.878 1.4 3.053.918 3.995.78 5.323 1.508 7H.43c-2.128-5.697 4.165-8.83 7.394-5.857q.09.083.176.171a3 3 0 0 1 .176-.17c3.23-2.974 9.522.159 7.394 5.856h-1.078c.728-1.677.59-3.005.108-3.947C13.486.878 10.4.28 8.717 2.01zM2.212 10h1.315C4.593 11.183 6.05 12.458 8 13.795c1.949-1.337 3.407-2.612 4.473-3.795h1.315c-1.265 1.566-3.14 3.25-5.788 5-2.648-1.75-4.523-3.434-5.788-5"/><path d="M10.464 3.314a.5.5 0 0 0-.945.049L7.921 8.956 6.464 5.314a.5.5 0 0 0-.88-.091L3.732 8H.5a.5.5 0 0 0 0 1H4a.5.5 0 0 0 .416-.223l1.473-2.209 1.647 4.118a.5.5 0 0 0 .945-.049l1.598-5.593 1.457 3.642A.5.5 0 0 0 12 9h3.5a.5.5 0 0 0 0-1h-3.162z"/></svg>`,
          },
          {
            title: '폐질환',
            desc: '분진·유해물질 노출로 인한 진폐증, 석면 폐암',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 16 16"><path d="M8.5 1.5a.5.5 0 1 0-1 0v5.243L7 7.1V4.72C7 3.77 6.23 3 5.28 3c-.524 0-1.023.27-1.443.592-.431.332-.847.773-1.216 1.229-.736.908-1.347 1.946-1.58 2.48-.176.405-.393 1.16-.556 2.011-.165.857-.283 1.857-.241 2.759.04.867.233 1.79.838 2.33.67.6 1.622.556 2.741-.004l1.795-.897A2.5 2.5 0 0 0 7 11.264V10.5a.5.5 0 0 0-1 0v.764a1.5 1.5 0 0 1-.83 1.342l-1.794.897c-.978.489-1.415.343-1.628.152-.28-.25-.467-.801-.505-1.63-.037-.795.068-1.71.224-2.525.157-.82.357-1.491.491-1.8.19-.438.75-1.4 1.44-2.25.342-.422.703-.799 1.049-1.065.358-.276.639-.385.833-.385a.72.72 0 0 1 .72.72v3.094l-1.79 1.28a.5.5 0 0 0 .58.813L8 7.614l3.21 2.293a.5.5 0 1 0 .58-.814L10 7.814V4.72a.72.72 0 0 1 .72-.72c.194 0 .475.11.833.385.346.266.706.643 1.05 1.066.688.85 1.248 1.811 1.439 2.249.134.309.334.98.491 1.8.156.814.26 1.73.224 2.525-.038.829-.224 1.38-.505 1.63-.213.19-.65.337-1.628-.152l-1.795-.897A1.5 1.5 0 0 1 10 11.264V10.5a.5.5 0 0 0-1 0v.764a2.5 2.5 0 0 0 1.382 2.236l1.795.897c1.12.56 2.07.603 2.741.004.605-.54.798-1.463.838-2.33.042-.902-.076-1.902-.24-2.759-.164-.852-.38-1.606-.558-2.012-.232-.533-.843-1.571-1.579-2.479-.37-.456-.785-.897-1.216-1.229C11.743 3.27 11.244 3 10.72 3 9.77 3 9 3.77 9 4.72V7.1l-.5-.357z"/></svg>`,
          },
          {
            title: '직업성 암',
            desc: '발암물질 노출로 인정받는 직업성 암 산재',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0a1 1 0 0 1 1 1v1.402c0 .511.677.693.933.25l.7-1.214a1 1 0 0 1 1.733 1l-.701 1.214c-.256.443.24.939.683.683l1.214-.701a1 1 0 0 1 1 1.732l-1.214.701c-.443.256-.262.933.25.933H15a1 1 0 1 1 0 2h-1.402c-.512 0-.693.677-.25.933l1.214.701a1 1 0 1 1-1 1.732l-1.214-.7c-.443-.257-.939.24-.683.682l.701 1.214a1 1 0 1 1-1.732 1l-.701-1.214c-.256-.443-.933-.262-.933.25V15a1 1 0 1 1-2 0v-1.402c0-.512-.677-.693-.933-.25l-.701 1.214a1 1 0 0 1-1.732-1l.7-1.214c.257-.443-.24-.939-.682-.683l-1.214.701a1 1 0 1 1-1-1.732l1.214-.701c.443-.256.261-.933-.25-.933H1a1 1 0 1 1 0-2h1.402c.511 0 .693-.677.25-.933l-1.214-.701a1 1 0 1 1 1-1.732l1.214.701c.443.256.939-.24.683-.683l-.701-1.214a1 1 0 0 1 1.732-1l.701 1.214c.256.443.933.261.933-.25V1a1 1 0 0 1 1-1m2 5a1 1 0 1 0-2 0 1 1 0 0 0 2 0M6 7a1 1 0 1 0-2 0 1 1 0 0 0 2 0m1 4a1 1 0 1 0 0-2 1 1 0 0 0 0 2m5-3a1 1 0 1 0-2 0 1 1 0 0 0 2 0"/></svg>`,
          },
          {
            title: '유족보상',
            desc: '산재 사망 시 유가족 보상금·연금 청구',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 16 16"><path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4"/></svg>`,
          },
          {
            title: '출퇴근 재해',
            desc: '출퇴근 중 사고 산재 인정 신청 대행',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 16 16"><path d="M4 9a1 1 0 1 1-2 0 1 1 0 0 1 2 0m10 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0M6 8a1 1 0 0 0 0 2h4a1 1 0 1 0 0-2zM4.862 4.276 3.906 6.19a.51.51 0 0 0 .497.731c.91-.073 2.35-.17 3.597-.17s2.688.097 3.597.17a.51.51 0 0 0 .497-.731l-.956-1.913A.5.5 0 0 0 10.691 4H5.309a.5.5 0 0 0-.447.276"/><path d="M2.52 3.515A2.5 2.5 0 0 1 4.82 2h6.362c1 0 1.904.596 2.298 1.515l.792 1.848c.075.175.21.319.38.404.5.25.855.715.965 1.262l.335 1.679q.05.242.049.49v.413c0 .814-.39 1.543-1 1.997V13.5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5v-1.338c-1.292.048-2.745.088-4 .088s-2.708-.04-4-.088V13.5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5v-1.892c-.61-.454-1-1.183-1-1.997v-.413a2.5 2.5 0 0 1 .049-.49l.335-1.68c.11-.546.465-1.012.964-1.261a.8.8 0 0 0 .381-.404l.792-1.848ZM4.82 3a1.5 1.5 0 0 0-1.379.91l-.792 1.847a1.8 1.8 0 0 1-.853.904.8.8 0 0 0-.43.564L1.03 8.904a1.5 1.5 0 0 0-.03.294v.413c0 .796.62 1.448 1.408 1.484 1.555.07 3.786.155 5.592.155s4.037-.084 5.592-.155A1.48 1.48 0 0 0 15 9.611v-.413q0-.148-.03-.294l-.335-1.68a.8.8 0 0 0-.43-.563 1.8 1.8 0 0 1-.853-.904l-.792-1.848A1.5 1.5 0 0 0 11.18 3z"/></svg>`,
          },
          {
            title: '불승인 이의신청',
            desc: '산재 불승인 결정에 대한 심사청구·재심사',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 16 16"><path d="M5.338 1.59a61 61 0 0 0-2.837.856.48.48 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533q.18.085.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .1-.025q.114-.034.294-.118c.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56"/><path d="M10.854 5.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647a.5.5 0 0 1 .708 0"/></svg>`,
          },
        ].map((service) => (
          <div class="group bg-white p-7 hover:bg-stone-50 transition-colors">
            <div class="w-9 h-9 mb-5 text-gray-400 group-hover:text-gold-400/60 transition-colors" set:html={service.icon} />
            <div class="w-8 h-0.5 bg-gold-500 mb-5 group-hover:w-14 transition-all duration-300"></div>
            <h3 class="font-bold text-navy-900 mb-2">{service.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-gold-600 font-semibold text-sm tracking-widest uppercase mb-2">왜 하온인가</p>
          <h2 class="text-2xl md:text-4xl font-black text-navy-900 leading-tight mb-10">
            산재 전문 대표 공인노무사, 전문성으로 결과를 입증합니다
          </h2>
          <div class="space-y-8">
            {[
              { title: '첫 무료 상담부터 보상까지', desc: '접수부터 보상금 수령까지 대표 공인노무사가 직접 관리합니다.' },
              { title: '투명한 수임료, 성공보수제', desc: '근로자 분들의 산재 상담은 무료로 진행되며, 산재 승인 이후 성공보수를 받습니다. 근로자분들의 부담을 최소화하며, 자신있게 사건을 진행합니다.' },
              { title: '불승인에도 포기하지 않습니다', desc: '산재 신청 후 불승인 결정을 받으셨나요? 심사청구, 재심사청구까지 함께 싸웁니다.' },
              { title: '평균임금 정정', desc: '산재 승인을 받았는데 보상금이 적으신가요? 근로기준법, 평균임금 산정 특례 등 다양한 법령의 전문가로서 도움을 드리겠습니다.' },
            ].map((item, i) => (
              <div class="flex gap-6">
                <span class="text-3xl font-black text-gold-400/40 leading-none shrink-0 select-none">{String(i + 1).padStart(2, '0')}</span>
                <div>
                  <h3 class="font-bold text-navy-900 mb-1">{item.title}</h3>
                  <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div>
          <div class="bg-navy-900 rounded-2xl p-8 text-white">
            <h3 class="text-lg font-bold mb-8 text-gold-400 tracking-wide">산재 처리 절차</h3>
            <div class="space-y-0">
              {[
                { step: '01', title: '무료 상담', desc: '사고·질병 경위 파악 및 산재 가능성 분석' },
                { step: '02', title: '쟁점 파악', desc: '의무기록, 4대보험자료, 소득금액증명원 등 자료 수집 및 의학적·법리적 쟁점 파악' },
                { step: '03', title: '산재 신청', desc: '근로복지공단 관할지사에 요양급여·장해급여 등 청구' },
                { step: '04', title: '공단 대응', desc: '근로복지공단 조사 대응, 추가 자료 제출' },
                { step: '05', title: '보상금 수령', desc: '휴업급여, 장해등급 신청 및 평균임금 정정 등 진행' },
              ].map((step, i, arr) => (
                <div class="flex gap-5">
                  <div class="flex flex-col items-center">
                    <div class="w-9 h-9 border border-gold-500/50 text-gold-400 rounded-full flex items-center justify-center font-bold text-xs shrink-0">{step.step}</div>
                    {i < arr.length - 1 && <div class="w-px bg-white/10 flex-1 my-2"></div>}
                  </div>
                  <div class="pb-6">
                    <p class="font-bold text-white text-sm">{step.title}</p>
                    <p class="text-sm text-gray-400 mt-0.5">{step.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent cases -->
  <section class="py-20 bg-navy-900">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-12">
        <p class="text-gold-400 font-semibold text-sm tracking-widest uppercase mb-2">실제 사례</p>
        <h2 class="text-3xl md:text-4xl font-black text-white">최근 성공 사례</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10">
