---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/url';
---

<Layout title="홈" description="하온 노동법률사무소 - 산재 전문 공인 노무사. 소음성 난청, 근골격계, 심뇌혈관, 직업성 암, 출퇴근재해 등 무료 상담">

  <!-- Hero -->
  <section class="relative bg-navy-900 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-blue-950 opacity-90"></div>
    <div class="absolute inset-0" style="background-image:url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.03\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-24 md:py-36">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-gold-500/20 border border-gold-500/40 text-gold-400 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
          <span class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></span>
          산재 전문 공인 노무사
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6">
          당신의 권리를<br />
          <span class="text-gold-400">되찾아</span> 드립니다
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-10 max-w-xl">
          산업재해, 출퇴근 재해, 직업성 질병 등 복잡한 산재 신청부터 불승인 이의 신청까지.
          하온 노동법률사무소가 끝까지 함께합니다.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={url('/consulting')} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold text-base rounded-xl transition-colors shadow-lg shadow-gold-500/30">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            무료상담 신청하기
          </a>
          <a href="tel:01023151579" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/30 hover:bg-white/10 text-white font-semibold text-base rounded-xl transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            010-2315-1579
          </a>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative border-t border-white/10 bg-black/20">
      <div class="max-w-6xl mx-auto px-4 py-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { number: '2,400+', label: '사건 수행 경험' },
          { number: '98%', label: '승인율' },
          { number: '15년', label: '전문 경력' },
          { number: '무료', label: '산재 상담' },
        ].map((stat) => (
          <div>
            <div class="text-2xl md:text-3xl font-black text-gold-400">{stat.number}</div>
            <div class="text-sm text-gray-400 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-blue-600 font-semibold text-sm uppercase tracking-wider mb-2">전문 서비스</p>
        <h2 class="text-3xl md:text-4xl font-black text-navy-900">산재 유형별 전문 대응</h2>
        <p class="mt-4 text-gray-500 max-w-xl mx-auto">업종과 질병 유형에 따라 최적화된 전략으로 승인을 이끌어냅니다</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { icon: '🦻', title: '소음성 난청', desc: '오랜 소음 노출로 인한 직업성 청력손실 산재 처리', href: url('/guides/hearing-loss') },
          { icon: '🦴', title: '근골격계 질환', desc: '반복 작업·과부하로 인한 요통, 손목 등 산재', href: url('/guides/musculoskeletal') },
          { icon: '🫀', title: '심뇌혈관 질환', desc: '과로·스트레스로 인한 뇌졸중, 심근경색 산재', href: url('/guides/cardiovascular') },
          { icon: '🫁', title: '폐질환', desc: '분진·유해물질 노출로 인한 진폐증, 석면 폐암', href: url('/guides/lung-disease') },
          { icon: '🎗️', title: '직업성 암', desc: '발암물질 노출로 인정받는 직업성 암 산재', href: url('/guides/occupational-cancer') },
          { icon: '🏠', title: '유족보상', desc: '산재 사망 시 유가족 보상금·연금 청구', href: url('/guides/survivors-compensation') },
          { icon: '🚌', title: '출퇴근 재해', desc: '출퇴근 중 사고 산재 인정 신청 대행', href: url('/guides/commuting-accident') },
          { icon: '📋', title: '불승인 이의신청', desc: '산재 불승인 결정에 대한 심사청구·재심사', href: url('/specialty') },
        ].map((service) => (
          <a href={service.href} class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-md border border-gray-100 hover:border-blue-100 transition-all">
            <div class="text-3xl mb-4">{service.icon}</div>
            <h3 class="font-bold text-navy-900 mb-2 group-hover:text-blue-700 transition-colors">{service.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{service.desc}</p>
            <div class="mt-4 flex items-center text-blue-600 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity">
              자세히 보기
              <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-blue-600 font-semibold text-sm uppercase tracking-wider mb-2">왜 하온인가</p>
          <h2 class="text-3xl md:text-4xl font-black text-navy-900 leading-tight mb-6">
            산재만 15년,<br />전문성이 결과를 만듭니다
          </h2>
          <div class="space-y-5">
            {[
              { title: '첫 상담부터 끝까지 직접 담당', desc: '접수부터 보상금 수령까지 대표 노무사가 직접 케이스를 관리합니다. 중간에 담당자가 바뀌는 일이 없습니다.' },
              { title: '불승인에도 포기하지 않습니다', desc: '산재 신청 후 불승인 결정을 받으셨나요? 심사청구, 재심사청구, 행정소송까지 함께 싸웁니다.' },
              { title: '투명한 수임료, 성공보수제', desc: '산재 상담은 완전 무료이며, 산재 승인 후 성공보수 방식으로 진행합니다. 의뢰인 부담을 최소화합니다.' },
              { title: '산업별 전문 네트워크', desc: '건설, 제조, 사무직 등 업종별 전문 지식과 산재 주치의 네트워크를 통해 의학적 입증을 지원합니다.' },
            ].map((item, i) => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-blue-600 text-white rounded-lg flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">{i + 1}</div>
                <div>
                  <h3 class="font-bold text-navy-900 mb-1">{item.title}</h3>
                  <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="relative">
          <div class="bg-navy-900 rounded-3xl p-8 text-white">
            <h3 class="text-xl font-bold mb-6 text-gold-400">산재 처리 절차</h3>
            <div class="space-y-0">
              {[
                { step: '01', title: '무료 상담', desc: '사고·질병 경위 파악 및 산재 가능성 분석' },
                { step: '02', title: '서류 준비', desc: '진단서, 재해경위서, 사업장 자료 수집' },
                { step: '03', title: '산재 신청', desc: '근로복지공단 요양급여·휴업급여 신청' },
                { step: '04', title: '심사 대응', desc: '공단 조사 대응, 추가 소명 자료 제출' },
                { step: '05', title: '보상 수령', desc: '요양비, 휴업급여, 장해급여 등 수령' },
              ].map((step, i, arr) => (
                <div class="flex gap-4">
                  <div class="flex flex-col items-center">
                    <div class="w-10 h-10 bg-gold-500 rounded-full flex items-center justify-center text-navy-900 font-black text-xs shrink-0">{step.step}</div>
                    {i < arr.length - 1 && <div class="w-0.5 bg-gold-500/30 flex-1 my-1"></div>}
                  </div>
                  <div class="pb-5">
                    <p class="font-bold text-white">{step.title}</p>
                    <p class="text-sm text-gray-400 mt-0.5">{step.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent cases -->
  <section class="py-20 bg-blue-700">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-blue-300 font-semibold text-sm uppercase tracking-wider mb-2">실제 사례</p>
        <h2 class="text-3xl md:text-4xl font-black text-white">최근 성공 사례</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { badge: '소음성 난청', result: '산재 승인', title: '25년 조선소 근무 용접공', desc: '양측 고주파 청력손실 45dB로 처음엔 불승인 → 작업환경 소음 측정 데이터와 직업력 정밀 분석으로 재심 승인', amount: '장해급여 약 4,200만원' },
          { badge: '심뇌혈관', result: '산재 승인', title: 'IT회사 팀장 뇌경색', desc: '프로젝트 마감 전 주 80시간 이상 초과근무 입증. 뇌혈관 질환과 업무 과부하 상당인과관계 인정', amount: '장해급여 + 휴업급여 약 8,700만원' },
          { badge: '직업성 암', result: '유족급여 지급', title: '도장공 폐암 유족보상', desc: '30년 이상 도장 작업 중 벤젠 등 발암물질 노출 입증. 망인의 폐암과 직업 연관성 인정 후 유족급여 수령', amount: '유족급여 약 1억 2,000만원' },
        ].map((c) => (
          <div class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/20">
            <div class="flex items-center justify-between mb-4">
              <span class="bg-gold-500 text-navy-900 text-xs font-bold px-3 py-1 rounded-full">{c.badge}</span>
              <span class="text-green-300 text-xs font-semibold flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {c.result}
              </span>
            </div>
            <h3 class="font-bold text-white text-lg mb-2">{c.title}</h3>
            <p class="text-blue-200 text-sm leading-relaxed mb-4">{c.desc}</p>
            <p class="text-gold-400 font-semibold text-sm">{c.amount}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={url('/cases')} class="inline-flex items-center gap-2 bg-white text-blue-700 font-bold px-8 py-3 rounded-xl hover:bg-blue-50 transition-colors">
          전체 사례 보기
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-navy-900 mb-4">지금 바로 무료 상담 받으세요</h2>
      <p class="text-gray-500 mb-8 leading-relaxed">
        산재 신청 가능 여부가 불확실하신가요? 먼저 상담부터 해보세요.
        경험 많은 노무사가 15분 내 가능성을 판단해 드립니다.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={url('/consulting')} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-navy-900 hover:bg-navy-800 text-white font-bold rounded-xl transition-colors">
          온라인 상담 신청
        </a>
        <a href="tel:01023151579" class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-navy-900 text-navy-900 font-bold rounded-xl hover:bg-navy-900 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          전화 상담: 010-2315-1579
        </a>
      </div>
    </div>
  </section>
</Layout>
