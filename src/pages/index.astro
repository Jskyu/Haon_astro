---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/url';
---

<Layout title="홈" description="하온 노동법률사무소 - 산재 전문 공인 노무사. 소음성 난청, 근골격계, 심뇌혈관, 직업성 암, 출퇴근재해 등 무료 상담">

  <!-- Hero -->
  <section class="bg-navy-900 text-white">
    <div class="max-w-6xl mx-auto px-4 py-24 md:py-36">
      <div class="max-w-2xl">
        <p class="text-gold-400 text-sm font-semibold tracking-widest mb-5 uppercase">산재 전문 공인노무사</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6">
          <span class="text-gold-400">하</span>늘아래 모든 분들이<br />
          <span class="text-gold-400">온</span>전한 행복을 누릴 수 있도록
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-10 max-w-xl">
          산업재해, 업무상질병 등 복잡한 산재 신청부터 평균임금 정정, 불승인 이의제기까지.
          하온 노동법률사무소가 끝까지 함께합니다.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={url('/consulting')} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold text-base rounded-xl transition-colors">
            무료상담 신청하기
          </a>
          <a href="tel:01023151579" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/30 hover:bg-white/10 text-white font-semibold text-base rounded-xl transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            010-2315-1579
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-12">
        <p class="text-gold-600 font-semibold text-sm tracking-widest uppercase mb-2">전문 서비스</p>
        <h2 class="text-3xl md:text-4xl font-black text-navy-900">산재 유형별 전문 대응</h2>
        <p class="mt-4 text-gray-500 max-w-xl">업종과 질병 유형에 따라 최적화된 전략으로 승인을 이끌어냅니다</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-gray-200">
        {[
          { title: '소음성 난청', desc: '오랜 소음 노출로 인한 직업성 청력손실 산재 처리' },
          { title: '근골격계 질환', desc: '인공관절 수술, 허리디스크, 어깨, 손목 등의 산재 처리' },
          { title: '뇌심혈관 질환', desc: '과로·스트레스로 인한 뇌출혈, 거미막하출혈, 급성심근경색 등' },
          { title: '폐질환', desc: '분진·유해물질 노출로 인한 진폐증, 석면 폐암' },
          { title: '직업성 암', desc: '발암물질 노출로 인정받는 직업성 암 산재' },
          { title: '유족보상', desc: '산재 사망 시 유가족 보상금·연금 청구' },
          { title: '출퇴근 재해', desc: '출퇴근 중 사고 산재 인정 신청 대행' },
          { title: '불승인 이의신청', desc: '산재 불승인 결정에 대한 심사청구·재심사' },
        ].map((service) => (
          <div class="group bg-white p-7 hover:bg-stone-50 transition-colors">
            <div class="w-8 h-0.5 bg-gold-500 mb-5 group-hover:w-14 transition-all duration-300"></div>
            <h3 class="font-bold text-navy-900 mb-2">{service.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-gold-600 font-semibold text-sm tracking-widest uppercase mb-2">왜 하온인가</p>
          <h2 class="text-3xl md:text-4xl font-black text-navy-900 leading-tight mb-10">
            산재 전문 대표 공인노무사,<br />전문성으로 결과를 입증합니다
          </h2>
          <div class="space-y-8">
            {[
              { title: '첫 무료 상담부터 보상까지', desc: '접수부터 보상금 수령까지 대표 공인노무사가 직접 관리합니다.' },
              { title: '투명한 수임료, 성공보수제', desc: '근로자 분들의 산재 상담은 무료로 진행되며, 산재 승인 이후 성공보수를 받습니다. 근로자분들의 부담을 최소화하며, 자신있게 사건을 진행합니다.' },
              { title: '불승인에도 포기하지 않습니다', desc: '산재 신청 후 불승인 결정을 받으셨나요? 심사청구, 재심사청구까지 함께 싸웁니다.' },
              { title: '평균임금 정정', desc: '산재 승인을 받았는데 보상금이 적으신가요? 근로기준법, 평균임금 산정 특례 등 다양한 법령의 전문가로서 도움을 드리겠습니다.' },
            ].map((item, i) => (
              <div class="flex gap-6">
                <span class="text-3xl font-black text-gold-400/40 leading-none shrink-0 select-none">{String(i + 1).padStart(2, '0')}</span>
                <div>
                  <h3 class="font-bold text-navy-900 mb-1">{item.title}</h3>
                  <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div>
          <div class="bg-navy-900 rounded-2xl p-8 text-white">
            <h3 class="text-lg font-bold mb-8 text-gold-400 tracking-wide">산재 처리 절차</h3>
            <div class="space-y-0">
              {[
                { step: '01', title: '무료 상담', desc: '사고·질병 경위 파악 및 산재 가능성 분석' },
                { step: '02', title: '쟁점 파악', desc: '의무기록, 4대보험자료, 소득금액증명원 등 자료 수집 및 의학적·법리적 쟁점 파악' },
                { step: '03', title: '산재 신청', desc: '근로복지공단 관할지사에 요양급여·장해급여 등 청구' },
                { step: '04', title: '공단 대응', desc: '근로복지공단 조사 대응, 추가 자료 제출' },
                { step: '05', title: '보상금 수령', desc: '휴업급여, 장해등급 신청 및 평균임금 정정 등 진행' },
              ].map((step, i, arr) => (
                <div class="flex gap-5">
                  <div class="flex flex-col items-center">
                    <div class="w-9 h-9 border border-gold-500/50 text-gold-400 rounded-full flex items-center justify-center font-bold text-xs shrink-0">{step.step}</div>
                    {i < arr.length - 1 && <div class="w-px bg-white/10 flex-1 my-2"></div>}
                  </div>
                  <div class="pb-6">
                    <p class="font-bold text-white text-sm">{step.title}</p>
                    <p class="text-sm text-gray-400 mt-0.5">{step.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent cases -->
  <section class="py-20 bg-navy-900">
    <div class="max-w-6xl mx-auto px-4">
      <div class="mb-12">
        <p class="text-gold-400 font-semibold text-sm tracking-widest uppercase mb-2">실제 사례</p>
        <h2 class="text-3xl md:text-4xl font-black text-white">최근 성공 사례</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10">
        {[
          { badge: '근골격계', title: '건설업 15년 근무 형틀목공', desc: '"나이가 들어서 그렇겠지"라며 주저하셨으나, 의학적·법리적 쟁점 분석 및 인과관계 입증하여 산재 승인', amount: '장해급여 92,927,290원' },
          { badge: '뇌심혈관', title: '화물차 기사 급성심근경색', desc: '지병(고혈압)이 있으셨으나, 과로와 업무부담 가중요인 주장하여 산재 유족급여 인정', amount: '유족급여+장례비 114,648,590원 + 매月 연금' },
          { badge: '직업성 암', title: '자동차 공업사 근로자 폐암', desc: '업무 내용·근무환경 정리, 직업환경연구원 자료 및 산업안전보건공단 자료 등 제출하여 업무 중 발암물질 노출 입증을 통해 폐암 승인', amount: '병원비, 휴업급여 61,590,320원 등' },
        ].map((c) => (
          <div class="bg-navy-900 p-8">
            <span class="text-xs font-semibold text-gold-400 tracking-wider uppercase">{c.badge}</span>
            <h3 class="font-bold text-white text-lg mt-3 mb-3">{c.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-6">{c.desc}</p>
            <p class="text-gold-400 font-bold text-sm border-t border-white/10 pt-4">{c.amount}</p>
          </div>
        ))}
      </div>
      <div class="mt-10">
        <a href="https://blog.naver.com/jswcpla/224054356423" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-white/30 hover:border-gold-400 text-white hover:text-gold-400 font-semibold px-7 py-3 rounded-xl transition-colors text-sm">
          전체 사례 보기
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-navy-900 mb-4">지금 바로 무료 상담 받으세요</h2>
      <p class="text-gray-500 mb-10 leading-relaxed">
        산재 신청 가능 여부가 불확실하신가요? 먼저 상담부터 해보세요.
        경험 많은 노무사가 15분 내 가능성을 판단해 드립니다.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={url('/consulting')} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-navy-900 hover:bg-navy-800 text-white font-bold rounded-xl transition-colors">
          온라인 상담 신청
        </a>
        <a href="tel:01023151579" class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-navy-900 text-navy-900 font-bold rounded-xl hover:bg-navy-900 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          전화 상담: 010-2315-1579
        </a>
      </div>
    </div>
  </section>
</Layout>
