---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/url';

const specialties = [
  {
    icon: '🦻',
    title: '소음성 난청',
    href: '/guides/hearing-loss',
    desc: '장기간 소음 환경에서 근무한 결과 발생하는 청력손실. 85dB 이상 소음 작업장 10년 이상 근무 시 산재 신청 가능.',
    tags: ['조선업', '건설업', '제조업', '광업'],
  },
  {
    icon: '🦴',
    title: '근골격계 질환',
    href: '/guides/musculoskeletal',
    desc: '반복 동작, 과도한 힘, 불편한 자세로 인한 요통·관절염·손목 질환 등. 사무직·생산직 모두 해당 가능.',
    tags: ['요추 추간판 탈출증', '회전근개 파열', '수근관 증후군', '경추 질환'],
  },
  {
    icon: '🫀',
    title: '심뇌혈관 질환',
    href: '/guides/cardiovascular',
    desc: '과로, 교대근무, 극심한 스트레스로 인한 뇌경색·심근경색·뇌출혈. 발병 전 12주 업무 부하량이 핵심.',
    tags: ['뇌졸중', '심근경색', '뇌출혈', '협심증'],
  },
  {
    icon: '🫁',
    title: '폐질환',
    href: '/guides/lung-disease',
    desc: '탄광·조선·건설 작업장의 분진 흡입으로 인한 진폐증, 석면 노출에 의한 중피종·폐암 등.',
    tags: ['진폐증', '석면 관련 질환', '직업성 천식', '만성 폐쇄성 폐질환'],
  },
  {
    icon: '🎗️',
    title: '직업성 암',
    href: '/guides/occupational-cancer',
    desc: '발암물질 노출로 인한 직업성 암. 벤젠(백혈병), 석면(폐암), 방사선(갑상선암) 등 특정 암종 인정.',
    tags: ['방광암', '폐암', '중피종', '백혈병'],
  },
  {
    icon: '🏠',
    title: '유족보상',
    href: '/guides/survivors-compensation',
    desc: '업무 중 사망 또는 직업성 질환으로 사망한 경우 유족에게 지급되는 연금·일시금 청구 대행.',
    tags: ['유족급여', '장의비', '유족연금', '일시금'],
  },
  {
    icon: '🚌',
    title: '출퇴근 재해',
    href: '/guides/commuting-accident',
    desc: '2018년 1월부터 통상적 경로의 출퇴근 중 사고도 산재로 인정. 도로, 대중교통, 자전거 사고 모두 해당.',
    tags: ['교통사고', '낙상', '대중교통 사고', '자전거 사고'],
  },
  {
    icon: '⚖️',
    title: '불승인 이의신청',
    href: '/consulting',
    desc: '산재 신청 후 불승인 받으셨나요? 심사청구(90일), 재심사청구, 행정소송까지 단계별 대응합니다.',
    tags: ['심사청구', '재심사청구', '행정소송', '행정심판'],
  },
  {
    icon: '💊',
    title: '직업성 질환 전반',
    href: '/consulting',
    desc: '위 항목 외에도 화학물질 노출, 진동 장해, 방사선 피폭 등 다양한 직업성 질환을 다룹니다.',
    tags: ['진동 장해', '화학물질 중독', '방사선 질환', '감염병'],
  },
];
---

<Layout title="전문 분야" description="하온 노동법률사무소 전문 분야 - 소음성 난청, 근골격계, 심뇌혈관, 폐질환, 직업성 암, 출퇴근재해">

  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-sm text-gold-400 mb-2">
        <a href={url("/")} class="hover:underline">홈</a>
        <span class="mx-2">/</span>
        <span>전문 분야</span>
      </div>
      <h1 class="text-4xl font-black">전문 분야</h1>
      <p class="mt-3 text-gray-300 max-w-xl">
        하온 노동법률사무소는 모든 산재 유형에 대한 전문성을 갖추고 있습니다. 승인이 어려운 복잡한 사례일수록 더욱 강합니다.
      </p>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {specialties.map((s) => (
          <a
            href={s.href}
            class="group bg-white rounded-2xl p-7 shadow-sm hover:shadow-lg border border-gray-100 hover:border-blue-200 transition-all"
          >
            <div class="text-4xl mb-4">{s.icon}</div>
            <h2 class="text-lg font-bold text-navy-900 group-hover:text-blue-700 transition-colors mb-3">
              {s.title}
            </h2>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">{s.desc}</p>
            <div class="flex flex-wrap gap-2">
              {s.tags.map((tag) => (
                <span class="text-xs bg-blue-50 text-blue-700 px-2.5 py-1 rounded-full font-medium">
                  {tag}
                </span>
              ))}
            </div>
            <div class="mt-5 flex items-center text-blue-600 text-sm font-semibold">
              자세히 알아보기
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-navy-900 mb-4">산재 처리, 이렇게 도와드립니다</h2>
      <p class="text-gray-500 mb-12">복잡한 산재 절차, 처음부터 끝까지 함께합니다</p>
      <div class="grid grid-cols-1 sm:grid-cols-5 gap-4 items-start">
        {[
          { n: '1', title: '무료 상담', sub: '사례 분석 및\n가능성 판단' },
          { n: '2', title: '자료 수집', sub: '의무기록·\n작업환경 자료' },
          { n: '3', title: '산재 신청', sub: '근로복지공단\n요양 신청' },
          { n: '4', title: '심사 대응', sub: '추가 소명\n적극 대응' },
          { n: '5', title: '보상 완료', sub: '급여 수령 및\n사후 관리' },
        ].map((step, i, arr) => (
          <div class="flex items-center gap-2 sm:flex-col sm:gap-0">
            <div class="text-center sm:w-full">
              <div class="w-12 h-12 bg-navy-900 text-white rounded-full flex items-center justify-center font-black text-lg mx-auto">
                {step.n}
              </div>
              <p class="font-bold text-navy-900 mt-3 text-sm">{step.title}</p>
              <p class="text-gray-400 text-xs mt-1 whitespace-pre-line">{step.sub}</p>
            </div>
            {i < arr.length - 1 && (
              <svg class="w-5 h-5 text-gray-300 shrink-0 sm:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 bg-navy-900 text-center text-white">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-black mb-3">내 상황이 산재에 해당하는지 궁금하신가요?</h2>
      <p class="text-gray-300 mb-8 text-sm">먼저 무료로 상담 받아보세요. 가능성이 없다면 솔직히 말씀드립니다.</p>
      <a href={url("/consulting")} class="inline-block px-10 py-4 bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold rounded-xl transition-colors">
        무료상담 신청
      </a>
    </div>
  </section>
</Layout>
