---
import Layout from '../layouts/Layout.astro';
import { url } from '../utils/url';
---

<Layout title="무료상담" description="하온 노동법률사무소 무료 산재 상담 신청 - 소음성 난청, 근골격계, 심뇌혈관, 직업성 암 등 전문 상담">

  <section class="bg-navy-900 text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-sm text-gold-400 mb-2">
        <a href={url("/")} class="hover:underline">홈</a>
        <span class="mx-2">/</span>
        <span>무료상담</span>
      </div>
      <h1 class="text-4xl font-black">무료상담 신청</h1>
      <p class="mt-3 text-gray-300 max-w-xl">
        상담 후 산재 가능성이 없다고 판단되는 경우 어떠한 비용도 청구하지 않습니다.
      </p>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-12">

        <!-- Form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
            <h2 class="text-2xl font-black text-navy-900 mb-2">상담 신청서</h2>
            <p class="text-sm text-gray-500 mb-8">모든 항목을 입력해 주시면 더 정확한 상담이 가능합니다. <span class="text-red-500">*</span> 표시는 필수 항목입니다.</p>

            <form id="consulting-form" class="space-y-6" novalidate>
              <!-- Name + Phone -->
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">
                    성함 <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    placeholder="홍길동"
                    required
                    class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">
                    연락처 <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="010-0000-0000"
                    required
                    class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                  />
                </div>
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">이메일</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="example@email.com"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                />
              </div>

              <!-- Consultation type -->
              <div>
                <label for="type" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  상담 분야 <span class="text-red-500">*</span>
                </label>
                <select
                  id="type"
                  name="type"
                  required
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white appearance-none"
                >
                  <option value="">— 해당 분야를 선택해 주세요 —</option>
                  <option value="hearing-loss">소음성 난청</option>
                  <option value="musculoskeletal">근골격계 질환 (요통, 관절, 손목 등)</option>
                  <option value="cardiovascular">심뇌혈관 질환 (뇌졸중, 심근경색)</option>
                  <option value="lung-disease">폐질환 (진폐증, 석면, 천식)</option>
                  <option value="occupational-cancer">직업성 암</option>
                  <option value="survivors-compensation">유족보상</option>
                  <option value="commuting-accident">출퇴근 재해</option>
                  <option value="appeal">산재 불승인 이의신청</option>
                  <option value="other">기타</option>
                </select>
              </div>

              <!-- Work type -->
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="industry" class="block text-sm font-semibold text-gray-700 mb-1.5">업종</label>
                  <input
                    type="text"
                    id="industry"
                    name="industry"
                    placeholder="예: 건설업, 제조업, 사무직"
                    class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                  />
                </div>
                <div>
                  <label for="workYears" class="block text-sm font-semibold text-gray-700 mb-1.5">근무 기간</label>
                  <input
                    type="text"
                    id="workYears"
                    name="workYears"
                    placeholder="예: 10년 3개월"
                    class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                  />
                </div>
              </div>

              <!-- Status -->
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-3">현재 상태</label>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                  {['산재 신청 전', '신청 심사 중', '불승인 받음', '기타'].map((s) => (
                    <label class="flex items-center gap-2 cursor-pointer p-3 border border-gray-200 rounded-xl hover:border-blue-300 hover:bg-blue-50 transition-colors">
                      <input type="radio" name="status" value={s} class="accent-blue-600" />
                      <span class="text-sm text-gray-600">{s}</span>
                    </label>
                  ))}
                </div>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  상황 설명 <span class="text-red-500">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  placeholder="다치거나 질병이 발생한 경위, 증상, 현재 상황 등을 자유롭게 작성해 주세요. 구체적일수록 더 정확한 상담이 가능합니다."
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
                ></textarea>
              </div>

              <!-- Contact time -->
              <div>
                <label for="contactTime" class="block text-sm font-semibold text-gray-700 mb-1.5">선호 연락 시간</label>
                <select
                  id="contactTime"
                  name="contactTime"
                  class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white"
                >
                  <option value="">상관없음</option>
                  <option value="morning">오전 9시 – 12시</option>
                  <option value="afternoon">오후 12시 – 15시</option>
                  <option value="late">오후 15시 – 18시</option>
                  <option value="sat">토요일</option>
                </select>
              </div>

              <!-- Privacy -->
              <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
                <input type="checkbox" id="privacy" name="privacy" required class="mt-0.5 accent-blue-600" />
                <label for="privacy" class="text-sm text-gray-600 cursor-pointer">
                  <span class="font-semibold text-gray-800">[필수] 개인정보 수집 및 이용에 동의합니다.</span><br />
                  수집 항목: 성함, 연락처, 이메일 / 목적: 상담 진행 / 보유 기간: 상담 완료 후 1년
                </label>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                class="w-full py-4 bg-navy-900 hover:bg-navy-800 text-white font-bold text-base rounded-xl transition-colors flex items-center justify-center gap-2"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
                무료상담 신청하기
              </button>
            </form>

            <!-- Error message (hidden by default) -->
            <div id="error-msg" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 text-center">
              전송 중 오류가 발생했습니다. 잠시 후 다시 시도하거나 <a href="tel:01023151579" class="font-semibold underline">전화</a>로 문의해 주세요.
            </div>

            <!-- Success message (hidden by default) -->
            <div id="success-msg" class="hidden text-center py-12">
              <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-xl font-black text-navy-900 mb-2">상담 신청이 완료되었습니다!</h3>
              <p class="text-gray-500 text-sm">영업일 기준 24시간 이내에 연락드리겠습니다.<br />급하신 경우 <a href="tel:01023151579" class="text-blue-600 font-semibold hover:underline">010-2315-1579</a>로 바로 전화해 주세요.</p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Direct contact -->
          <div class="bg-navy-900 text-white rounded-2xl p-6">
            <h3 class="font-bold text-lg mb-4">바로 연락하기</h3>
            <div class="space-y-4">
              <a href="tel:01023151579" class="flex items-center gap-3 p-3.5 bg-white/10 hover:bg-white/20 rounded-xl transition-colors">
                <div class="w-10 h-10 bg-gold-500 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-navy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400">전화 상담</p>
                  <p class="font-bold">010-2315-1579</p>
                </div>
              </a>
              <a href="mailto:jswcpla@gmail.com" class="flex items-center gap-3 p-3.5 bg-white/10 hover:bg-white/20 rounded-xl transition-colors">
                <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400">이메일</p>
                  <p class="font-bold text-sm">jswcpla@gmail.com</p>
                </div>
              </a>
            </div>
          </div>

          <!-- FAQ -->
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h3 class="font-bold text-navy-900 mb-5">자주 묻는 질문</h3>
            <div class="space-y-4" id="faq">
              {[
                {
                  q: '상담 비용이 있나요?',
                  a: '산재 상담은 완전 무료입니다. 산재 승인 후 성공보수를 받습니다.',
                },
                {
                  q: '다른 지역에서도 상담 가능한가요?',
                  a: '전국 어디서든 전화·이메일·방문 상담이 가능합니다.',
                },
                {
                  q: '불승인 받았는데 다시 신청할 수 있나요?',
                  a: '네, 심사청구(90일 이내), 재심사청구, 행정소송 등 단계별로 대응 가능합니다.',
                },
                {
                  q: '산재 신청 시효가 있나요?',
                  a: '요양급여는 3년, 장해급여는 5년, 유족급여는 5년의 소멸시효가 있습니다. 빠를수록 좋습니다.',
                },
              ].map((faq, i) => (
                <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
                  <button
                    class="w-full flex items-start justify-between text-left gap-2 text-sm font-semibold text-gray-800 faq-btn"
                    data-index={i}
                  >
                    <span>Q. {faq.q}</span>
                    <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5 faq-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="hidden faq-answer mt-2 text-sm text-gray-500 leading-relaxed">{faq.a}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<script is:inline>
  // ─── EmailJS 설정값 ───────────────────────────────────────────────
  // emailjs.com 에서 발급 후 아래 세 값을 교체하세요.
  var EMAILJS_PUBLIC_KEY  = 'TI1CwzyxQ1AzqaTw1';   // Account > General
  var EMAILJS_SERVICE_ID  = 'service_kew48ve';   // Email Services 탭
  var EMAILJS_TEMPLATE_ID = 'template_yx0e5gl';  // Email Templates 탭
  // ──────────────────────────────────────────────────────────────────

  emailjs.init({ publicKey: EMAILJS_PUBLIC_KEY });

  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var answer = btn.nextElementSibling;
      var icon = btn.querySelector('.faq-icon');
      answer && answer.classList.toggle('hidden');
      icon && icon.classList.toggle('rotate-180');
    });
  });

  // Form submit
  var form = document.getElementById('consulting-form');
  var successMsg = document.getElementById('success-msg');
  var errorMsg = document.getElementById('error-msg');
  var submitBtn = form && form.querySelector('button[type="submit"]');
  var submitBtnOriginalHTML = submitBtn && submitBtn.innerHTML;

  form && form.addEventListener('submit', function(e) {
    e.preventDefault();

    var required = form.querySelectorAll('[required]');
    var valid = true;

    required.forEach(function(el) {
      if (!el.value.trim() || (el.type === 'checkbox' && !el.checked)) {
        valid = false;
        el.classList.add('ring-2', 'ring-red-400', 'border-red-400');
        el.addEventListener('input', function() {
          el.classList.remove('ring-2', 'ring-red-400', 'border-red-400');
        }, { once: true });
      }
    });

    if (!valid) {
      var firstInvalid = form.querySelector('.ring-red-400');
      firstInvalid && firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    // 전송 중 버튼 비활성화
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path></svg> 전송 중...';
    }
    errorMsg && errorMsg.classList.add('hidden');

    emailjs.sendForm(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, form)
      .then(function() {
        form.classList.add('hidden');
        successMsg && successMsg.classList.remove('hidden');
      })
      .catch(function(err) {
        console.error('EmailJS 오류:', err);
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = submitBtnOriginalHTML;
        }
        errorMsg && errorMsg.classList.remove('hidden');
      });
  });
</script>
